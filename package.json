{
    "name": "tagparse",
    "description": "AST-first templating library for Discord and chat bots. Parse {variable}, {if:cond|then|else}, {each:items|template} placeholder syntax with safe rendering helpers.",
    "version": "2.0.0",
    "main": "./dist/cjs/index.cjs",
    "module": "./dist/esm/index.mjs",
    "types": "./dist/esm/index.d.mts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/esm/index.d.mts",
                "default": "./dist/esm/index.mjs"
            },
            "require": {
                "types": "./dist/cjs/index.d.ts",
                "default": "./dist/cjs/index.cjs"
            }
        },
        "./discord": {
            "import": {
                "types": "./dist/esm/discord.d.mts",
                "default": "./dist/esm/discord.mjs"
            },
            "require": {
                "types": "./dist/cjs/discord.d.ts",
                "default": "./dist/cjs/discord.cjs"
            }
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup",
        "test": "vitest run",
        "test:watch": "vitest",
        "bench": "node --import tsx test/bench.ts",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "check": "biome check --write .",
        "typecheck": "tsc --noEmit",
        "ci": "pnpm run typecheck && biome ci . && pnpm run test",
        "changeset:version": "changeset version",
        "changeset:publish": "pnpm run build && changeset publish --tag next"
    },
    "keywords": [
        "discord",
        "discord-bot",
        "discord-template",
        "discord-templating",
        "chat-bot",
        "template-engine",
        "templating",
        "placeholder",
        "string-interpolation",
        "tag-parser",
        "parser",
        "ast",
        "lexer",
        "tokenizer",
        "mustache-alternative",
        "string-template",
        "message-template",
        "embed-template",
        "typescript",
        "esm",
        "cjs",
        "ikigai"
    ],
    "author": "ItsAmziii",
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.13",
        "@changesets/cli": "^2.31.0",
        "@types/node": "^22.19.17",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vitest": "^2.1.9"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/itsamziii/tagparse.git"
    },
    "homepage": "https://github.com/itsamziii/tagparse#readme",
    "bugs": {
        "url": "https://github.com/itsamziii/tagparse/issues"
    }
}
